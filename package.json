{
  "name": "storybook-addon-mock-date",
  "version": "3.0.2",
  "description": "Storybook addon that mocks the JavaScript Date for individual stories.",
  "keywords": [
    "storybook-addon",
    "data-state",
    "mock-date",
    "mocking",
    "date",
    "time",
    "fake-timers"
  ],
  "license": "MIT",
  "author": "k35o <kosakanoki@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/k35o/storybook-addon-mock-date.git"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "type": "module",
  "exports": {
    "./preview": {
      "types": "./dist/preview.d.ts",
      "default": "./dist/preview.js"
    },
    "./manager": "./dist/manager.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "build:watch": "vp pack --watch",
    "typecheck": "tsc --noEmit",
    "check": "vp check",
    "check:write": "vp check --fix",
    "test": "vitest run",
    "start": "run-p build:watch 'storybook --quiet'",
    "release": "pnpm run build && changeset publish",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@sinonjs/fake-timers": "15.4.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@k8o/oxc-config": "0.1.2",
    "@storybook/addon-docs": "next",
    "@storybook/addon-vitest": "next",
    "@storybook/icons": "2.0.2",
    "@storybook/react-vite": "next",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/sinonjs__fake-timers": "15.0.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser-playwright": "4.1.7",
    "npm-run-all2": "9.0.0",
    "playwright": "1.60.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "storybook": "next",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plus": "0.1.22",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "storybook": "^10.0.0"
  },
  "overrides": {
    "storybook": "$storybook"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.2.1",
  "storybook": {
    "displayName": "Mocking Date",
    "icon": "https://raw.githubusercontent.com/k35o/storybook-addon-mock-date/main/.github/icon.png"
  }
}
