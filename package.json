{
  "name": "storybook-addon-mock-date",
  "version": "2.0.0",
  "description": "Storybook addon to mocking date",
  "keywords": [
    "mock-date",
    "storybook-addon"
  ],
  "license": "MIT",
  "author": "k35o <kosakanoki@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/k35o/storybook-addon-mock-date.git"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "type": "module",
  "exports": {
    "./preview": {
      "types": "./dist/preview.d.ts",
      "default": "./dist/preview.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "build:watch": "vp pack --watch",
    "typecheck": "tsc --noEmit",
    "check": "vp check",
    "check:write": "vp check --fix",
    "test": "vitest run",
    "start": "run-p build:watch 'storybook --quiet'",
    "release": "pnpm run build && changeset publish",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@sinonjs/fake-timers": "15.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.5.2",
    "@changesets/cli": "2.29.8",
    "@k8o/oxc-config": "0.1.2",
    "@storybook/addon-docs": "next",
    "@storybook/addon-vitest": "next",
    "@storybook/react-vite": "next",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/sinonjs__fake-timers": "15.0.1",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.5",
    "npm-run-all": "4.1.5",
    "playwright": "1.59.1",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "storybook": "next",
    "typescript": "5.9.3",
    "vite": "8.0.10",
    "vite-plus": "0.1.19",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "storybook": "^10.0.0"
  },
  "overrides": {
    "storybook": "$storybook"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "pnpm@10.33.2",
  "storybook": {
    "displayName": "Mocking Date",
    "supportedFrameworks": [
      "supported-frameworks"
    ],
    "icon": "https://user-images.githubusercontent.com/321738/63501763-88dbf600-c4cc-11e9-96cd-94adadc2fd72.png"
  }
}
